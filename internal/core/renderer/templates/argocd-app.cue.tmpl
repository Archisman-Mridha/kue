{
  metadata: {
    name: "{{ .Name }}"
    namespace: "argocd"
  }

  spec: {
    source: {
      repoURL: "{{ .RepoURL }}"
      targetRevision: "HEAD"
      path: "{{ .SourcePath }}"
    }
    destination: {
      server: "https://kubernetes.default.svc"
      namespace: "default"
    }
    syncPolicy: syncOptions: [
      "CreateNamespace=true",
      "ApplyOutOfSyncOnly=true",
      "ServerSideApply=true"
    ]
  }
}
